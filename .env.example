# Database
DB_NAME=dars_ma
DB_USER=dars_ma_app
DB_PASSWORD=changeme

# Auth
# Must be >= 32 bytes (256 bits) for HMAC-SHA — generate with: openssl rand -base64 48
JWT_SIGNING_KEY=changeme-must-be-at-least-32-bytes-long-for-hmac-sha-256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7
# refresh_token cookie Secure flag — false only for local http dev, MUST be true in staging/prod (HTTPS)
COOKIE_SECURE=false

# Verification documents — AES-256 key, base64-encoded (32 raw bytes) — generate with: openssl rand -base64 32
VERIFICATION_DOC_ENC_KEY=changeme-must-be-base64-encoded-32-raw-bytes

# Payment (CMI escrow) — mode=mock uses MockEscrowPaymentProvider, no real creds needed
CMI_MODE=mock
CMI_MERCHANT_ID=
CMI_API_KEY=

# Email notifications
SMTP_HOST=
SMTP_PORT=

# Backend
SPRING_PROFILES_ACTIVE=dev

# Frontend calls relative /api/* paths — Nginx (prod) / ng serve proxy (dev) forward them to the backend,
# so no separate base URL is needed.

# Host-side port overrides (only matters for docker-compose on a dev machine running multiple projects)
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=4200
DB_HOST_PORT=5432
