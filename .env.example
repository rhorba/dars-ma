# Database
DB_NAME=dars_ma
DB_USER=dars_ma_app
DB_PASSWORD=changeme

# Auth
JWT_SIGNING_KEY=changeme-generate-rs256-keypair
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# Payment (CMI escrow) — mode=mock uses MockEscrowPaymentProvider, no real creds needed
CMI_MODE=mock
CMI_MERCHANT_ID=
CMI_API_KEY=

# Email notifications
SMTP_HOST=
SMTP_PORT=

# Backend
SPRING_PROFILES_ACTIVE=dev

# Frontend
ANGULAR_API_BASE_URL=http://localhost:8080
